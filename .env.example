# Core base URL used by the web app.
# The frontend will derive /api/v1 and /swagger-ui.html from this value.
NEXT_PUBLIC_CORE_BASE_URL=http://localhost:8080

# Comma-separated resource origins allowed by next/image.
# Example for demo deployment: http://demo.lab-edu.team:8080
NEXT_IMAGE_ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080
