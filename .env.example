# Browser-facing API base URL.
# Local standalone web+core:
# NEXT_PUBLIC_API_BASE_URL=http://localhost:8080/api/v1
# Domain-based routing with infra/nginx:
# NEXT_PUBLIC_API_BASE_URL=http://core.lab-edu.team/api/v1
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080/api/v1

# Swagger UI link shown in login page.
NEXT_PUBLIC_CORE_DOCS_URL=http://localhost:8080/swagger-ui.html
